<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZakatCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/dark_mid</item>
        <item name="colorOnPrimary">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:windowBackground">@color/dark_bg</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.ZakatCalculator.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ZakatCalculator</item>
    </style>
</resources>
